# Video Uniquifier — Local Worker Environment
# Copy this file to .env.local and fill in values from your Render dashboard

# Get these from Render → video-uniquifier → Environment
DATABASE_URL=
REDIS_URL=
R2_ACCESS_KEY=
R2_SECRET=
R2_BUCKET=
R2_ENDPOINT=

# GPU Encoding (set to false if NVENC has issues)
USE_NVENC=true
